# ============================================================
# 智能财富管家系统 - 环境变量配置模板
# 使用方式：复制此文件为 .env，填入真实值后启动
# cp .env.example .env
# ============================================================

# -------------------- MySQL 数据库 --------------------
MYSQL_HOST=192.168.110.59
MYSQL_PORT=3306
MYSQL_USER=offer
MYSQL_PASSWORD=123456
MYSQL_DATABASE=education_pro
MYSQL_POOL_SIZE=10
MYSQL_POOL_RECYCLE=3600
MYSQL_ECHO=false

# -------------------- Redis 缓存 --------------------
REDIS_HOST=192.168.110.59
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20
# 画像缓存 TTL（秒）
REDIS_PROFILE_TTL=604800
# 会话 TTL（秒）
REDIS_SESSION_TTL=1800

# -------------------- Milvus 向量数据库 --------------------
MILVUS_HOST=192.168.110.59
MILVUS_PORT=19530
MILVUS_COLLECTION_FAQ=faq_knowledge
MILVUS_COLLECTION_PRODUCT=product_knowledge
MILVUS_COLLECTION_POLICY=policy_knowledge
# 向量维度（取决于 Embedding 模型）
MILVUS_DIM=1536
# 检索 TopK
MILVUS_TOP_K=5
# 检索相似度阈值（低于此值触发兜底回答）
MILVUS_SCORE_THRESHOLD=0.65
# 检索超时（秒）
MILVUS_TIMEOUT=2

# -------------------- Neo4j 图数据库 --------------------
NEO4J_URI=bolt://192.168.110.59:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=078238Ab!
NEO4J_DATABASE=neo4j
# 图谱查询超时（秒）
NEO4J_TIMEOUT=3
# GraphRAG 融合排序权重（向量权重）
GRAPHRAG_VECTOR_WEIGHT=0.6
# GraphRAG 融合排序权重（图谱权重）
GRAPHRAG_GRAPH_WEIGHT=0.4

# -------------------- MinIO 对象存储 --------------------
MINIO_ENDPOINT=192.168.110.59:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_minio_secret
MINIO_BUCKET_DOCS=knowledge-docs
MINIO_SECURE=false

# -------------------- LLM 大模型 --------------------
# OpenAI API（主模型）
OPENAI_API_KEY=sk-0c6db3698ebb4f01a1c1cb039179738a
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL_CHAT=deepseek-v4-pro
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2048
OPENAI_TIMEOUT=30
#ollama本地embedding模型
OLLAMA_EMBED_URL=http://192.168.110.59:11434
OPENAI_MODEL_EMBEDDING=text-embedding-3-small
# API 调用失败重试
OPENAI_MAX_RETRIES=3
OPENAI_RETRY_DELAYS=1,2,4

# 本地模型（备用，OpenAI 不可用时降级）
LONGCAT_API_KEY=ak_2Pz1bP8VW0RN5L93rD8OZ1Tt6tN59
LONGCAT_BASE_URL=https://api.longcat.chat/openai
LONGCAT_MODEL=LongCat-2.0


# -------------------- JWT 认证（Mock 模式） --------------------
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
# Mock 模式：跳过真实认证
AUTH_MOCK_MODE=true

# -------------------- 流式输出 --------------------
SSE_ENABLED=true
SSE_CHUNK_SIZE=50

# -------------------- 分块策略 --------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# -------------------- 画像研判 --------------------
# 画像置信度衰减：每年衰减比例
PROFILE_CONFIDENCE_DECAY_RATE=0.2
# 证据累积每次增益
PROFILE_CONFIDENCE_EVIDENCE_GAIN=0.05
# 证据累积增益上限
PROFILE_CONFIDENCE_GAIN_MAX=0.3
# 冲突惩罚每次扣分
PROFILE_CONFIDENCE_CONFLICT_PENALTY=0.1
# 画像漂移检测阈值（行为匹配度）
PROFILE_DRIFT_THRESHOLD=0.6

# -------------------- 推荐引擎 --------------------
# 推荐排序权重
RECOMMEND_WEIGHT_RISK=0.40
RECOMMEND_WEIGHT_PREFERENCE=0.25
RECOMMEND_WEIGHT_DIVERSITY=0.20
RECOMMEND_WEIGHT_RETURN_TERM=0.15
# 默认返回 TopN
RECOMMEND_TOP_N=3

# -------------------- NL2SQL 安全 --------------------
NL2SQL_MAX_ROWS=100
# 禁止的 SQL 关键词（逗号分隔）
NL2SQL_BLOCKED_KEYWORDS=DROP,DELETE,UPDATE,INSERT,ALTER,TRUNCATE,CREATE

# -------------------- 日志 --------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
